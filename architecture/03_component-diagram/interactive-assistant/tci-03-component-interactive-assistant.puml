@startuml tci-03-component-interactive-assistant
!include <C4/C4_Component>
!include <tupadr3/font-awesome-5/laptop_code>
!include <tupadr3/font-awesome-5/user_check>
!include <tupadr3/font-awesome-5/tasks>
!include <tupadr3/font-awesome-5/brain>

LAYOUT_AS_SKETCH()
LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

skinparam nodesep 60
skinparam ranksep 70

' ── 액터 ──
Person(developer, "Developer", "미드~시니어 · AI 에이전트 활용", $sprite="laptop_code")
Person(reviewer, "Reviewer", "PR 리뷰 담당", $sprite="user_check")
Person(pmpo, "PM / PO", "요구사항 정의 · 의사결정", $sprite="tasks")

' ── 외부 시스템 ──
System_Ext(llm, "LLM Service", "OpenAI / Azure 등", $sprite="brain")

' ── 외부 TCI 컨테이너 ──
Container_Ext(analysisEngine, "Analysis Engine", "Python · CPG Query · LLM", "CPG 기반 구조 분석 · 영향도 분석\n비즈니스 규칙 추출 · Risk Insight · KB 구축")
ContainerDb_Ext(kb, "Knowledge Base", "Graph DB · Object Storage · Vector DB", "CPG 그래프 · 원본 스냅샷 · 분석 산출물\n임베딩 벡터")

' ══════ Interactive Assistant Boundary ══════
Container_Boundary(ia, "Interactive Assistant") {

  Component(ia_session, "Session Manager", "Python · WebSocket", "사용자 세션/연결 관리\n대화 이력 관리\n질의 이력 저장 및 팀 공유")

  Component(ia_router, "Query Router", "Python", "사용자 질의 의도 분류\n적절한 핸들러로 라우팅")

  together {
    Component(ia_qa, "QA Handler", "Python · LLM", "자연어 Q&A\n코드/구조/도메인 탐색\n답변 문서화 → KB 적재")
    Component(ia_explainer, "Codebase Explainer", "Python · LLM", "모듈/컴포넌트 발견\n기술설명/비즈니스룰\n문서 자동 생성")
    Component(ia_gap, "Gap Analyzer", "Python · LLM", "스펙-코드 불일치 탐지\n갭 심각도 분류\n리포트 생성")
    Component(ia_explain, "Explainability Engine", "Python · LLM", "분석 결과 기반\n구조/흐름 설명\n트랜잭션 흐름 요약")
  }

  together {
    Component(ia_context, "Context Assembler", "Python", "KB 검색 · RAG 컨텍스트 구성\n토큰 예산 관리\n사용자 범위/우선순위 설정")
    Component(ia_renderer, "Response Renderer", "Python", "LLM 응답 → UI 포맷 변환\n근거 링크(코드/문서/티켓) 포함\n답변 평가(Good/Bad) 수집")
  }
}

' ── 인바운드: 액터 → IA ──
Rel_D(developer, ia_session, "코드 탐색 · Q&A\n코드베이스 설명", "WebSocket")
Rel_D(reviewer, ia_session, "구조 질의\n리스크 질의", "WebSocket")
Rel_D(pmpo, ia_session, "비즈니스 규칙 탐색\n갭 분석 질의", "WebSocket")

note top of developer
  사용자 접근은 Web Application 경유 (C2 참조)
end note

' ── 내부: Session → Router → Handlers ──
Rel_D(ia_session, ia_router, "사용자 메시지 전달")
Rel_D(ia_router, ia_qa, "Q&A 의도")
Rel_D(ia_router, ia_explainer, "코드베이스 설명")
Rel_D(ia_router, ia_gap, "갭 분석")
Rel_D(ia_router, ia_explain, "분석 결과 설명")

' ── 내부: Handlers → Context Assembler ──
Rel_D(ia_qa, ia_context, "컨텍스트 요청")
Rel_D(ia_explainer, ia_context, "컨텍스트 요청")
Rel_D(ia_gap, ia_context, "컨텍스트 요청")
Rel_D(ia_explain, ia_context, "컨텍스트 요청")

' ── 내부: Handlers → Renderer ──
Rel_D(ia_qa, ia_renderer, "답변 전달")
Rel_D(ia_explainer, ia_renderer, "설명 전달")
Rel_D(ia_gap, ia_renderer, "갭 리포트 전달")
Rel_D(ia_explain, ia_renderer, "설명 전달")

' ── 내부: Renderer → Session (응답 반환) ──
Rel_U(ia_renderer, ia_session, "렌더링된 응답 반환")

' ── 아웃바운드: IA → KB ──
Rel_D(ia_context, kb, "구조/규칙/분석 결과 검색", "Graph Read")
Rel(ia_qa, kb, "답변 → KB 적재", "Graph Write")
Rel(ia_session, kb, "질의 이력 저장", "Write")
Rel(ia_renderer, kb, "답변 평가(Good/Bad) 저장", "Write")

' ── 아웃바운드: IA → Analysis Engine (비동기) ──
Rel(ia_qa, analysisEngine, "온디맨드 분석 요청", "async · gRPC")
Rel(ia_explainer, analysisEngine, "구조 분석 요청", "async · gRPC")
Rel(ia_gap, analysisEngine, "갭 분석 트리거", "async · gRPC")

' ── 아웃바운드: IA → LLM (대화형 추론) ──
Rel(ia_qa, llm, "대화형 추론", "REST/HTTPS")
Rel(ia_explainer, llm, "설명 생성", "REST/HTTPS")
Rel(ia_gap, llm, "갭 해석", "REST/HTTPS")
Rel(ia_explain, llm, "설명 생성", "REST/HTTPS")

' ══════ 레이아웃 힌트 ══════
Lay_R(developer, reviewer)
Lay_R(reviewer, pmpo)
Lay_R(ia_context, ia_renderer)
Lay_R(analysisEngine, kb)

@enduml
