@startuml tci-01-system-context
!include <C4/C4_Context>
!include <tupadr3/font-awesome-5/laptop_code>
!include <tupadr3/font-awesome-5/user_check>
!include <tupadr3/font-awesome-5/tasks>
!include <tupadr3/font-awesome-5/code_branch>
!include <tupadr3/font-awesome-5/ticket_alt>
!include <tupadr3/font-awesome-5/book>
!include <tupadr3/font-awesome-5/cogs>
!include <tupadr3/font-awesome-5/comments>
!include <tupadr3/font-awesome-5/robot>
!include <tupadr3/font-awesome-5/puzzle_piece>
!include <tupadr3/font-awesome-5/shield_alt>

title TCI System Context Diagram

LAYOUT_AS_SKETCH()
LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

' ── Actors ──
Person(developer, "Developer", "미드~시니어 · AI 에이전트 활용", $sprite="laptop_code")
Person(reviewer, "Reviewer", "PR 리뷰 담당", $sprite="user_check")
Person(pmpo, "PM / PO", "요구사항 정의 · 의사결정", $sprite="tasks")

' ── TCI ──
System(tci, "Tmax Code Intelligence", "코드·문서·이슈 등 개발 자산을 통합 수집·분석하여\n시스템 구조·영향 범위·비즈니스 맥락 기반\n이해·검토·판단을 지원")

' ── External Systems: Data Sources ──
Boundary(dataSources, "Data Sources") {
  System_Ext(git, "Git", "GitHub / GitLab / Bitbucket", $sprite="code_branch")
  System_Ext(ticket, "Ticket", "Jira / Azure DevOps", $sprite="ticket_alt")
  System_Ext(docs, "Docs / Wiki", "Confluence / Notion", $sprite="book")
}

' ── External Systems: Integration Channels ──
Boundary(channels, "Integration Channels") {
  System_Ext(cicd, "CI/CD", "Jenkins / GitHub Actions", $sprite="cogs")
  System_Ext(chatops, "ChatOps", "Slack / Teams", $sprite="comments")
  System_Ext(aiAgent, "AI Coding Agent", "MCP / API", $sprite="robot")
  System_Ext(idePlugin, "IDE Plugin", "VS Code / IntelliJ 확장", $sprite="puzzle_piece")
  System_Ext(policyEngine, "Policy Engine", "OPA / Custom Policy", $sprite="shield_alt")
}

' ── Actor ↔ TCI ──
Rel(developer, tci, "코드 탐색 · 영향 분석 · AI 컨텍스트")
Rel(developer, idePlugin, "로컬 Diff 캡처 · 영향 분석 요청")
Rel(reviewer, tci, "PR 리뷰 · 리스크 판단 · Policy Gate")
Rel(pmpo, tci, "스펙-구현 갭 분석 · 리포트 · 대시보드")

' ── TCI → External Systems ──
Rel_D(tci, git, "소스 코드 · 커밋 이력 수집", "Git / REST")
Rel_D(tci, ticket, "이슈 메타 수집 · 분석 코멘트", "REST API")
BiRel_D(tci, docs, "문서 수집 ↔ 생성 문서 발행", "REST API")
Rel_D(tci, cicd, "PR 이벤트 수신 · Gate 결과 응답", "Webhook / REST")
Rel_D(tci, chatops, "분석 알림 · 리스크 경고", "Bot API")
Rel_D(tci, aiAgent, "컨텍스트 패키지 교환", "MCP / REST")
BiRel_D(tci, idePlugin, "스냅샷 수신 · 분석 결과 반환", "REST/HTTPS")
Rel_D(tci, policyEngine, "정책 검증 요청 · 위반 결과 수신", "REST")

@enduml
