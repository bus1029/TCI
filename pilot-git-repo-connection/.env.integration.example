# Docker compose로 띄운 PostgreSQL/Redis를 사용하는 통합 테스트용 예시

TCI_PROJECT_ROOT=/Users/seokhyunbae_1/Desktop/기획_스프린트/TCI/pilot-git-repo-connection
TCI_ENV=development
TCI_RUNTIME_ROOT=.runtime
TCI_GIT_MIRROR_ROOT=.runtime/git-mirrors
TCI_CODE_SNAPSHOT_ROOT=.runtime/code-snapshots
TCI_TEMPLATE_ROOT=src/tci/web/templates

# docker-compose 기준 PostgreSQL / Redis 연결 정보
TCI_DATABASE_URL=postgresql+psycopg://tci:tci@127.0.0.1:5432/tci
TCI_REDIS_URL=redis://127.0.0.1:6379/0

# 로컬 통합 테스트용 Fernet 키를 별도로 생성해 넣어야 한다.
# 예:
# python - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
TCI_CREDENTIAL_ENCRYPTION_KEY=cSffDpusT2ljhQ0UTCVNCuVfQyhfT6ijQPtdNPyLpqI=

# destructive migration smoke는 테스트 전용 DB에만 사용해야 한다.
# 같은 DB를 써도 되지만, 가능하면 별도 테스트 DB를 권장한다.
TCI_TEST_DATABASE_URL=postgresql+psycopg://tci:tci@127.0.0.1:5432/tci
TCI_ALLOW_DESTRUCTIVE_MIGRATION_TESTS=0
